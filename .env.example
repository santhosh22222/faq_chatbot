# ══════════════════════════════════════════════════════════════════════════════
#  FAQBot — Environment Variables
#  ─────────────────────────────────────────────────────────────────────────────
#  1. Copy this file:   cp .env.example .env
#  2. Fill in your real values below
#  3. NEVER commit .env to version control (it's in .gitignore)
# ══════════════════════════════════════════════════════════════════════════════


# ── Groq API ──────────────────────────────────────────────────────────────────
#
#  Get your free key at: https://console.groq.com/keys
#  Supported models (configured in groq_client.py):
#    • llama-3.3-70b-versatile  ← default, best quality
#    • llama-3.1-70b-versatile
#    • llama-3.1-8b-instant     ← fastest
#    • gemma2-9b-it
#
GROQ_API_KEY=your_groq_api_key_here


# ── MongoDB ───────────────────────────────────────────────────────────────────
#
#  Local dev:
#    MONGODB_URI=mongodb://localhost:27017
#
#  Cloud (Render / production) — use MongoDB Atlas:
#    1. Create free cluster at https://cloud.mongodb.com
#    2. Security → Network Access → Add IP: 0.0.0.0/0  (allows Render's dynamic IPs)
#    3. Security → Database Access → create user with readWrite role
#    4. Deployment → Connect → Drivers → copy the SRV connection string
#    5. Replace <user> / <pass> / <cluster> with your actual values
#
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=faqbot


# ── Google OAuth (optional — enables "Sign in with Google") ──────────────────
#
#  Steps to set up:
#    1. Go to https://console.cloud.google.com/apis/credentials
#    2. Create a project (or select existing)
#    3. Enable "Google Identity" / "Google+ API"
#    4. Create → OAuth 2.0 Client ID (type: Web application)
#    5. Add Authorised redirect URIs:
#         http://localhost:8501              ← local dev
#         https://your-app.onrender.com     ← production (add your real URL)
#    6. Copy the Client ID and Client Secret below
#
#  Leave blank to disable Google Sign-In (email/password login still works).
#
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8501
