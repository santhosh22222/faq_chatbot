# ──────────────────────────────────────────────────────
#  FAQBot — Environment Variables
#  Copy this file to `.env` and fill in your values.
#  NEVER commit your real `.env` to version control.
# ──────────────────────────────────────────────────────

# Groq API key — get yours free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here


# ── MongoDB ───────────────────────────────────────────────────────────────────
#
#  Local dev:    mongodb://localhost:27017
#  Render/cloud: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true
#
#  For Render deployment:
#    1. Create a free cluster at https://cloud.mongodb.com
#    2. Network Access → Add IP → 0.0.0.0/0
#    3. Connect → Drivers → copy the SRV URI
#    4. Paste it as MONGODB_URI in Render → Environment Variables
#
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=faqbot


# ── Google OAuth (optional — enables "Sign in with Google") ──────────────────
#
#  1. Go to https://console.cloud.google.com/apis/credentials
#  2. Create a project → Enable "Google+ API" / "Google Identity"
#  3. Create OAuth 2.0 Client ID  (type: Web application)
#  4. Add Authorised redirect URI:  http://localhost:8501
#     (for production, add your real domain too)
#  5. Copy Client ID and Client Secret below.
#
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8501
